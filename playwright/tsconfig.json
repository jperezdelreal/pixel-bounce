{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["tests/**/*.ts", "lib/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "test-results"]
}
