{
  "name": "@syntaxsorcery/playwright-gameplay-template",
  "version": "1.0.0",
  "description": "Reusable Playwright gameplay testing framework for HTML5 canvas games. Part of the Syntax Sorcery constellation.",
  "type": "commonjs",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test tests/smoke.spec.ts",
    "test:gameplay": "npx playwright test tests/gameplay.spec.ts",
    "test:menus": "npx playwright test tests/menu-navigation.spec.ts",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:report": "npx playwright test --reporter=json > test-results.json",
    "create-issues": "node scripts/create-issues-from-failures.js",
    "postinstall": "npx playwright install chromium"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.8.3"
  },
  "keywords": ["playwright", "game-testing", "e2e", "visual-testing", "html5-canvas"],
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  }
}
